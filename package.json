{
  "name": "warplets-api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "SKIP_JFS_VERIFICATION=true tsx watch src/server.ts",
    "dev:snap": "wrangler dev --env dev --port 8789",
    "dev:tunnel": "node scripts/dev-tunnel.mjs",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@farcaster/snap": "^1.22.1",
    "@farcaster/snap-hono": "~1.5.12",
    "@noble/curves": "^2.0.0",
    "hono": "^4.12.12",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@hono/node-server": "^1.19.13",
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "wrangler": "^4.0.0"
  }
}
