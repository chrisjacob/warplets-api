{
  "name": "10x-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "deploy": "vite build && wrangler pages deploy dist",
    "local:tunnel": "node ../scripts/dev-tunnel-app.mjs",
    "local:tunnel:drop": "node ../scripts/dev-tunnel-drop.mjs",
    "security:preflight": "node ../scripts/security-preflight.mjs",
    "deploy:dev": "pnpm security:preflight && vite build --mode development && wrangler pages deploy dist --project-name 10x-app-dev --branch dev",
    "deploy:prod": "pnpm security:preflight && vite build && wrangler pages deploy dist --project-name 10x-app"
  },
  "dependencies": {
    "@farcaster/miniapp-node": "^0.2.0",
    "@farcaster/miniapp-sdk": "^0.3.0",
    "@neynar/ui": "^1",
    "canvas-confetti": "^1.9.4",
    "react": "^19",
    "react-dom": "^19",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.31.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@tailwindcss/vite": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^6",
    "wrangler": "^4.0.0"
  }
}
